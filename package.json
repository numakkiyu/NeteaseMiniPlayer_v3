{
  "name": "netease-mini-player-workspace",
  "version": "3.0.0-alpha.0",
  "private": true,
  "type": "module",
  "description": "NeteaseMiniPlayer v3 and v3 Plus workspace.",
  "license": "Apache-2.0",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate": "pnpm typecheck && pnpm test && pnpm lint && pnpm format:check"
  },
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@types/node": "22.0.0",
    "eslint": "^9.8.0",
    "globals": "^15.9.0",
    "playwright": "1.56.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
