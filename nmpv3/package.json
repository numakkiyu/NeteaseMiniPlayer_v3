{
  "name": "netease-mini-player-v3",
  "version": "3.0.0-alpha.1",
  "type": "module",
  "description": "Lightweight single-JS NetEase Cloud Music player.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/numakkiyu/NeteaseMiniPlayer_v3#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/numakkiyu/NeteaseMiniPlayer_v3.git",
    "directory": "nmpv3"
  },
  "bugs": {
    "url": "https://github.com/numakkiyu/NeteaseMiniPlayer_v3/issues"
  },
  "keywords": [
    "netease",
    "music-player",
    "web-component",
    "cdn",
    "wordpress"
  ],
  "main": "./dist/nmpv3.min.js",
  "module": "./dist/nmpv3.es.js",
  "types": "./dist/nmpv3.d.ts",
  "unpkg": "./dist/nmpv3.min.js",
  "jsdelivr": "./dist/nmpv3.min.js",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "import": "./dist/nmpv3.es.js",
      "types": "./dist/nmpv3.d.ts"
    },
    "./auto": {
      "import": "./dist/nmpv3.es.js",
      "types": "./dist/nmpv3.d.ts"
    },
    "./browser": "./dist/nmpv3.min.js"
  },
  "sideEffects": true,
  "scripts": {
    "build": "vite build && tsc -p tsconfig.json --emitDeclarationOnly --declaration --declarationMap false && node -e \"const fs=require('fs'); if (fs.existsSync('dist/index.d.ts')) fs.copyFileSync('dist/index.d.ts','dist/nmpv3.d.ts')\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {}
}
